# ============================================================
# 온변 환경변수 설정 가이드
# 이 파일을 .env.local로 복사 후 실제 값을 입력하세요.
# .env.local은 절대 Git에 커밋하지 않습니다.
# ============================================================

# ── Anthropic Claude API ─────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── NextAuth ─────────────────────────────────────────────────
# 랜덤 시크릿: openssl rand -base64 32
NEXTAUTH_SECRET=
# 개발: http://localhost:3000 / 프로덕션: https://onbyun.vercel.app
NEXTAUTH_URL=

# ── Google OAuth ─────────────────────────────────────────────
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
# 승인된 리디렉션 URI: https://onbyun.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Supabase ─────────────────────────────────────────────────
# https://supabase.com → 프로젝트 → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 클라이언트용 (anon key, NEXT_PUBLIC_ 사용 가능)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 토스페이먼츠 ─────────────────────────────────────────────
# https://developers.tosspayments.com → 내 개발정보 → API 키
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
# 클라이언트 키 (결제창 호출용, NEXT_PUBLIC_ 사용 가능)
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# ── 이메일 (NextAuth Email Provider) ─────────────────────────
# Resend(https://resend.com) 또는 SendGrid 권장
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@onbyun.com
